{
  "manifest_version": 3,
  "name": "Pyrus IBKR Paper Login Guard",
  "version": "1.0.0",
  "description": "Locks the hosted IBKR login surface to Paper Trading mode.",
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5000/*",
        "http://127.0.0.1:5000/*"
      ],
      "js": ["paper-only.js"],
      "run_at": "document_start"
    }
  ]
}
