{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; export PORT=${PORT:-8080} PGROOT=\"${PGROOT:-$(cd ../.. && pwd)/.local/postgres}\"; node ../../scripts/reap-dev-port.mjs && bash ../../scripts/start-local-postgres.sh && export DATABASE_URL=\"${DATABASE_URL:-postgres:///dev?host=${PGROOT}/run&user=runner}\" NODE_ENV=development && pnpm run build && exec node --enable-source-maps ./dist/index.mjs",
    "build": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; node ./build.mjs",
    "start": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; exec node --enable-source-maps ./dist/index.mjs",
    "test:unit": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; node --import tsx ./scripts/runUnitTests.mjs",
    "test:live:universe": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; node --test \"src/services/universe-search.live.test.mjs\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/ibkr-contracts": "workspace:*",
    "@workspace/account-math": "workspace:*",
    "@workspace/backtest-core": "workspace:*",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/rayreplica-core": "workspace:*",
    "cors": "catalog:",
    "drizzle-orm": "catalog:",
    "express": "catalog:",
    "pino": "catalog:",
    "pino-http": "catalog:",
    "ws": "catalog:"
  },
  "devDependencies": {
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "esbuild": "catalog:",
    "esbuild-plugin-pino": "catalog:",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
