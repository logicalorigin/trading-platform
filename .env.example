# Pyrus environment inventory.
# Copy only the variables you need into Replit Secrets or a local .env file.
# Leave secret values blank in this example.

# Core runtime
NODE_ENV=development
LOG_LEVEL=info
PYRUS_LOG_PRETTY=
PORT=8080
REPL_HOME=
PYRUS_SERVE_WEB=
PYRUS_API_PORT=8080
PYRUS_FRONTEND_PORT=18747
MALLOC_ARENA_MAX=
BASE_PATH=/
VITE_PROXY_API_TARGET=http://127.0.0.1:8080
VITE_API_BASE_URL=
API_BASE_URL=http://127.0.0.1:8080/api

# Auth bootstrap
PYRUS_AUTH_BOOTSTRAP_TOKEN=

# "Launch Platform" JWT handoff (Slice 6). The external parent site mints a short-lived
# RS256 JWT (it holds the private key; we hold only the public key). All three must be set
# for POST/GET /api/auth/launch to be enabled (otherwise it returns 503). LAUNCH_JWT_ISSUER
# is a comma-separated allow-list; newlines in the PEM may be escaped as \n.
LAUNCH_JWT_PUBLIC_KEY=
LAUNCH_JWT_ISSUER=
LAUNCH_JWT_AUDIENCE=

# Private marketing shadow dashboard feed
PYRUS_MARKETING_DASHBOARD_TOKEN=
# Optional: only add this during a planned token-rotation window.
# PYRUS_MARKETING_DASHBOARD_NEXT_TOKEN=

# Database
DATABASE_URL=
SOURCE_DATABASE_URL=
LOCAL_DATABASE_URL=
PYRUS_DATABASE_SOURCE=
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=
DB_CONNECTION_TIMEOUT_MS=
DB_QUERY_TIMEOUT_MS=
DB_STATEMENT_TIMEOUT_MS=
DB_IDLE_TX_TIMEOUT_MS=
DB_IDLE_TIMEOUT_MS=
DB_POOL_MAX=
DB_AUTH_POOL_MAX=
DB_TRADING_POOL_MAX=
# Slow pool-acquire diagnostic threshold in milliseconds (default 500).
DB_POOL_SLOW_ACQUIRE_DIAGNOSTIC_MS=500
# Slow-query diagnostic threshold in milliseconds (default 2000).
DB_QUERY_SLOW_DIAGNOSTIC_MS=2000
# Set to "false" to disable the database disk-usage guard (enabled by default).
DB_DISK_USAGE_GUARD_ENABLED=
# Postgres application_name suffix (pyrus-<value>); default "app".
PYRUS_DB_APP=
# Unset (or "api") gets the full pool (10-12); any other value caps it at 2.
PYRUS_DB_PROFILE=

# Market data providers
POLYGON_API_KEY=
POLYGON_KEY=
POLYGON_BASE_URL=
MASSIVE_API_KEY=
MASSIVE_MARKET_DATA_API_KEY=
MASSIVE_API_BASE_URL=
MASSIVE_BASE_URL=
MASSIVE_STOCKS_RECENCY=
MASSIVE_OPTIONS_RECENCY=
MASSIVE_OPTION_QUOTE_STREAM_UNCONFIGURED_RETRY_MS=
MASSIVE_TRADE_BAR_MAX_REFERENCE_DEVIATION=
MASSIVE_TRADE_BAR_MAX_REJECT_STREAK=
PYRUS_MASSIVE_STOCK_WS_STALE_RECONNECT_MS=
FMP_API_KEY=
FMP_KEY=
FMP_BASE_URL=
FINANCIALMODELINGPREP_API_KEY=
FINANCIAL_MODELING_PREP_API_KEY=
FINANCIAL_MODELING_PREP_BASE_URL=

# SnapTrade integration
SNAPTRADE_CLIENTID=
SNAPTRADE_API_KEY=
# Required before storing any SnapTrade per-user userSecret.
# Accepts a 32-byte key encoded as base64url, base64:<value>, or hex:<value>.
PYRUS_CREDENTIAL_ENCRYPTION_KEY=
PYRUS_CREDENTIAL_ENCRYPTION_KEY_VERSION=v1

# Robinhood Agentic Trading (MCP). OAuth clients are registered dynamically
# per connect (no partner keys); PYRUS_CREDENTIAL_ENCRYPTION_KEY above is
# required before tokens can be stored. Optional override for the OAuth
# redirect base; defaults to https://$REPLIT_DEV_DOMAIN.
ROBINHOOD_OAUTH_REDIRECT_BASE_URL=

# Schwab Trader API (developer.schwab.com app; confidential OAuth client).
# App key/secret come from the approved app's dashboard entry. Redirect base
# falls back to REPLIT_DEV_DOMAIN when unset. Refresh tokens hard-expire after
# 7 days (Schwab policy) so users re-authorize weekly.
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_OAUTH_REDIRECT_BASE_URL=

# IBKR hosted OAuth candidate (OAuth 1.0a). Third-party (multi-user) requires
# IBKR approval before customer use. SELF-SERVICE (own account) needs NO approval
# and uses the same crypto to build/validate. Do not confuse these with Client
# Portal Gateway tokens. See docs/plans/ibkr-oauth-selfservice-runbook.md.
# 9-char A-Z (self-service) / 25-hex (third-party).
IBKR_OAUTH_CONSUMER_KEY=
# RSA signing PRIVATE key (PEM); alias: IBKR_OAUTH_PRIVATE_KEY.
IBKR_OAUTH_SIGNING_KEY=
IBKR_OAUTH_PRIVATE_KEY=
# RSA encryption PRIVATE key (PEM); decrypts the access-token secret.
IBKR_OAUTH_ENCRYPTION_KEY=
# Diffie-Hellman params (dhparam PEM) or extracted prime hex.
IBKR_OAUTH_DH_PARAM=
# Self-service: issued by the IBKR portal.
IBKR_OAUTH_ACCESS_TOKEN=
# Self-service: RSA-encrypted secret from the portal.
IBKR_OAUTH_ACCESS_TOKEN_SECRET=
# Third-party only.
IBKR_OAUTH_CALLBACK_URL=
IBKR_OAUTH_THIRD_PARTY_APPROVED=

# IBKR Client Portal Gateway (hosted, no-approval bridge). We run IBKR's Java
# clientportal.gw in-container, one gateway process per connected app user, and
# proxy the browser login through our public domain. No IBKR OAuth vendor
# approval required. Defaults assume the runtime staged under IBKR_PORTAL_HOME
# (jre/ + gw/). Trading + account only. Default is <repo>/.pyrus-runtime/ibkr-cpg
# (gitignored, survives Replit container resets); provision with
# `node scripts/ensure-ibkr-portal-runtime.mjs`.
IBKR_PORTAL_HOME=
IBKR_PORTAL_JAVA_BIN=
IBKR_PORTAL_GW_DIR=
IBKR_PORTAL_BASE_PORT=5200
IBKR_PORTAL_MAX_GATEWAYS=4
# Production fleet routing is fail-closed and disabled by default. The API root
# key is a 32-byte base64url secret; each approved host receives only its
# host-ID-derived key in IBKR_SESSION_HOST_CONTROL_KEY.
IBKR_GATEWAY_FLEET_ENABLED=0
IBKR_GATEWAY_FLEET_CONTROL_ROOT_KEY=
# Legacy shared control token for the loopback development host only.
IBKR_SESSION_HOST_CONTROL_TOKEN=
# Production host identity and 32-byte base64url HMAC key. Configure both;
# signed host-bound requests take precedence over the legacy token.
IBKR_SESSION_HOST_ID=
IBKR_SESSION_HOST_CONTROL_KEY=
# Required with the signed host identity above. The lifecycle API origin is
# restricted to exact loopback HTTP; immutable identity/spec/attestation values
# are compared during quarantined host approval and contain no credentials.
IBKR_SESSION_HOST_API_ORIGIN=http://127.0.0.1:8080
IBKR_SESSION_HOST_WORKLOAD_IDENTITY_DIGEST=
IBKR_SESSION_HOST_RUNTIME_SPEC_DIGEST=
IBKR_SESSION_HOST_RUNTIME_ATTESTATION_DIGEST=
IBKR_SESSION_HOST_FAILURE_DOMAIN=
# Set to "1" to route hosted IBKR sessions through the local session host.
IBKR_SESSION_HOST_ENABLED=0
# Loopback IBKR session-host base URL (default http://127.0.0.1:18748).
IBKR_SESSION_HOST_URL=http://127.0.0.1:18748
# Immutable image digest required by the isolated paper-session capsule.
IBKR_SESSION_CAPSULE_IMAGE=
IBKR_SESSION_HOST_BIND=127.0.0.1
# Per-host measured density (1-20). Keep at 1 until the synthetic density gate
# certifies a higher value; the global control plane still caps admission at 20.
IBKR_SESSION_HOST_CAPACITY=1
IBKR_SESSION_HOST_MODE=paper
IBKR_SESSION_HOST_PORT=18748
# Isolated login origin; falls back to Replit-provided REPLIT_EXPO_DEV_DOMAIN.
IBKR_PORTAL_EMBED_ORIGIN=

# SPEC §6 compliance kill-switch (Slice 7). IBKR CPG for non-admin members is OFF
# until the IBKR ToS/OAuth-approval question is resolved. Members also need the
# `ibkr_access` entitlement; admins bypass. Leave false until compliance clears.
IBKR_MEMBER_CONNECT_ENABLED=false

# Legacy retired IBKR desktop bridge tombstones (retired, ignored)
IBKR_BRIDGE_URL=
IBKR_BRIDGE_BASE_URL=

# Optional path overrides for the active persisted desktop-bridge lifecycle snapshot.
IBKR_BRIDGE_RUNTIME_OVERRIDE_FILE=
PYRUS_IBKR_BRIDGE_RUNTIME_OVERRIDE_FILE=
IBKR_GATEWAY_TRADING_HEALTH_TIMEOUT_MS=
IBKR_LIVE_WARMUP_BACKGROUND_HOLD_MS=

# IBKR Client Portal app-owned runtime
