modules = ["nodejs-20"]
run = "HOST=0.0.0.0 PORT=5000 node server/index.js --dev"
onBoot = "bash scripts/ensure_codex_shell_env.sh"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "HOST=0.0.0.0 PORT=5000 node server/index.js --dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 4200

[[ports]]
localPort = 5010
externalPort = 5000

[[ports]]
localPort = 5011
externalPort = 5173

[[ports]]
localPort = 5012
externalPort = 6000

[[ports]]
localPort = 5013
externalPort = 6800

[[ports]]
localPort = 5080
externalPort = 3000

[[ports]]
localPort = 5100
externalPort = 8000

[[ports]]
localPort = 5101
externalPort = 8008

[[ports]]
localPort = 5102
externalPort = 8080

[[ports]]
localPort = 5103
externalPort = 8081

[[ports]]
localPort = 5104
externalPort = 8099

[[ports]]
localPort = 5105
externalPort = 9000

[[ports]]
localPort = 5122
externalPort = 3001

[[ports]]
localPort = 5124
externalPort = 3002
exposeLocalhost = true

[[ports]]
localPort = 5126
externalPort = 3003

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[agent]
expertMode = true

[objectStorage]
defaultBucketID = "replit-objstore-f863bd11-037a-4a9e-bd37-ffef5e822f04"
