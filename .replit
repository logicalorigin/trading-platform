modules = ["nodejs-24", "python-3.11", "postgresql-16"]
audio = true

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[[ports]]
localPort = 3002

[[ports]]
localPort = 3007

[[ports]]
localPort = 3008
externalPort = 6000

[[ports]]
localPort = 4010
externalPort = 5173

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8091
externalPort = 6800

[[ports]]
localPort = 18081
externalPort = 8008

[[ports]]
localPort = 18082
externalPort = 8081
exposeLocalhost = true

[[ports]]
localPort = 18083
externalPort = 8099

[[ports]]
localPort = 18084
externalPort = 9000

[[ports]]
localPort = 18088
externalPort = 3002

[[ports]]
localPort = 18747
externalPort = 3000

[[ports]]
localPort = 18748
externalPort = 5000

[[ports]]
localPort = 18749
externalPort = 3001

[[ports]]
localPort = 18759
externalPort = 3003

[userenv]

[userenv.shared]
IBKR_TRANSPORT = "tws"
PYTHONPATH = "/home/runner/.codex/skills/.python-deps"
TZ = "America/Denver"

[nix]
channel = "stable-25_05"
