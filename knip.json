{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreFiles": [
    "lib/api-zod/src/generated/**",
    "scripts/run-options-contract-sweeps.mjs",
    "artifacts/api-server/scripts/sampleFlowPremiumDistribution.mjs"
  ],
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{ts,js,mjs}"],
      "project": ["scripts/**/*.{ts,js,mjs}"]
    },
    "artifacts/api-server": {
      "entry": [
        "src/index.ts",
        "build.mjs",
        "scripts/runUnitTests.mjs",
        "src/**/*.test.ts"
      ],
      "project": ["src/**/*.ts", "scripts/**/*.mjs"]
    },
    "artifacts/ibkr-bridge": {
      "entry": ["src/index.ts", "build.mjs", "src/**/*.test.ts"],
      "project": "src/**/*.ts",
      "ignoreDependencies": ["ws", "@types/ws"]
    },
    "artifacts/backtest-worker": {
      "entry": ["src/index.ts", "build.mjs", "src/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "artifacts/rayalgo": {
      "entry": [
        "src/main.tsx",
        "src/main.jsx",
        "index.html",
        "vite.config.ts",
        "scripts/runUnitTests.mjs",
        "src/**/*.test.{ts,tsx,js,jsx,mjs}"
      ],
      "project": ["src/**/*.{ts,tsx,js,jsx}", "scripts/**/*.mjs"],
      "ignoreDependencies": ["tailwindcss"]
    },
    "lib/api-spec": {
      "entry": ["src/index.ts", "scripts/**/*.{ts,mjs}"],
      "project": "src/**/*.ts"
    },
    "lib/api-zod": {
      "entry": ["src/index.ts"],
      "project": "src/**/*.ts"
    },
    "lib/api-client-react": {
      "entry": ["src/index.ts"],
      "project": "src/**/*.ts"
    },
    "lib/account-math": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "lib/db": {
      "entry": ["src/index.ts"],
      "project": "src/**/*.ts"
    },
    "lib/backtest-core": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "lib/rayreplica-core": {
      "entry": ["src/index.ts"],
      "project": "src/**/*.ts"
    },
    "lib/ibkr-contracts": {
      "entry": ["src/index.ts"],
      "project": "src/**/*.ts"
    }
  },
  "ignoreDependencies": [
    "@replit/vite-plugin-cartographer",
    "@replit/vite-plugin-dev-banner",
    "@replit/vite-plugin-runtime-error-modal"
  ]
}
