{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; export PORT=${PORT:-8080}; node ../../scripts/reap-dev-port.mjs && export NODE_ENV=development && pnpm run build && exec node --enable-source-maps ./dist/index.mjs",
    "build": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; node ./build.mjs",
    "start": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; exec node --enable-source-maps ./dist/index.mjs",
    "test:unit": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; node --import tsx ./scripts/runUnitTests.mjs",
    "test:live:universe": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; node --test \"src/services/universe-search.live.test.mjs\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/ibkr-contracts": "workspace:*",
    "@workspace/backtest-core": "workspace:*",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/rayreplica-core": "workspace:*",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
