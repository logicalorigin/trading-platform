modules = ["nodejs-24", "python-3.11", "postgresql-16"]
audio = true

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "artifacts/pyrus: web"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 18747
externalPort = 3000

[[ports]]
localPort = 19047
externalPort = 3001
exposeLocalhost = true

[[ports]]
localPort = 19122
externalPort = 80

[userenv]

[userenv.development]
IBKR_ASYNC_SIDECAR_ROUTING_ENABLED = "true"

[userenv.shared]
IBKR_TRANSPORT = "tws"
PYTHONPATH = "/home/runner/.codex/skills/.python-deps"
TZ = "America/Denver"

[nix]
channel = "stable-25_05"
