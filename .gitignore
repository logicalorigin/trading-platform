# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
target/
*.tsbuildinfo
.expo
.expo-shared

# secrets — never commit real env files (keep .env.example tracked)
.env
.env.*
!.env.example

# dependencies
node_modules
.pythonlibs/
.venv/
__pycache__/
*.pyc
.mypy_cache/
.pytest_cache/
.ruff_cache/

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# local agent/tool settings
.claude/
/.agents/skills/gstack/
/.agents/skills/make-interfaces-feel-better/
/skills-lock.json

# local agent coordination runtime state
/.agents/agent-chat/
/AGENT_CHAT.md
/AGENT_CHAT_archive_*.md
/AGENT_CHAT_MESSAGES*.jsonl
/AGENT_TASK_BOARD.md

# local vendored/runtime experiments
.vendor/

# pasted prompt/review attachments
attached_assets/

# local run artifacts and screenshots
output/
artifacts/*.log
scripts/reports/signal-options-greek-selector-smoke/
scripts/reports/open-acceptance/
scripts/reports/pyrus-performance-monitor/
reports/pattern-discovery-sweeps/

# local runtime registries
.pyrus-runtime/
artifacts/api-server/data/ibkr-remote-desktops.json
artifacts/api-server/data/ibkr-bridge-runtime-override.json

# accidental root shell arg artifacts
/'expirationDate'

# local release/download artifacts
artifacts/ibgateway-bridge-windows-current.tar.gz

# local Playwright output
artifacts/**/test-results/
artifacts/**/playwright-report/
artifacts/**/blob-report/
test-results/
playwright-report/
.headless-shots/
.gstack/

# vendored agent skill packs (1.3+ GB of assets — install locally, never commit)
.agents/skills/

# profiling + ephemeral multi-agent coordination artifacts
*.cpuprofile
AGENT_CHAT_LIVE.jsonl

# Codex/Claude watch scratch debris (screenshots, session JSON, pid/registry
# files) — agent checkpoints must not sweep these into commits
/.codex-watch/
/.codex-watch-*/
/.codex-log-watch/
