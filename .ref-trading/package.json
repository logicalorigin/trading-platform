{
  "name": "spy-options-trading-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node server/index.js --dev",
    "dev:full": "DEV_BACKGROUND_PROFILE=full node server/index.js --dev",
    "dev:ui": "vite",
    "build": "vite build",
    "test:research-overlay": "node --test src/research/hooks/researchExecutionOverlayUtils.test.js",
    "test:research-spot-chart": "node --test src/research/hooks/researchExecutionOverlayUtils.test.js src/components/research/researchChartInteractionPolicy.test.js src/components/research/researchSpotChartLifecycleUtils.test.js src/research/chart/displayModel.test.js src/research/chart/studyModel.test.js",
    "preview": "vite preview",
    "start": "NODE_ENV=production RESEARCH_SPOT_WARM_ENABLED=${RESEARCH_SPOT_WARM_ENABLED:-true} RESEARCH_SPOT_WARM_RUN_ON_START=${RESEARCH_SPOT_WARM_RUN_ON_START:-true} RESEARCH_SPOT_WARM_SYMBOLS=${RESEARCH_SPOT_WARM_SYMBOLS:-SPY,QQQ} node server/index.js",
    "session:start": "node scripts/codex_session_log.cjs start",
    "session:note": "node scripts/codex_session_log.cjs note",
    "session:recover": "node scripts/codex_session_log.cjs recover",
    "session:show": "node scripts/codex_session_log.cjs show",
    "runtime:relocate-data": "node scripts/relocate_runtime_data.mjs",
    "spot-history:seed": "node scripts/seed_research_spot_history.js",
    "spot-history:backfill-warm-state": "node scripts/backfill_research_spot_warm_state.js",
    "rayalgo:tranche1:matrix": "node scripts/rayalgo_tranche1_replay_matrix.mjs",
    "rayalgo:score-study": "node scripts/rayalgo_score_study.mjs",
    "rayalgo:indicator-mix": "node scripts/rayalgo_indicator_mix_report.mjs",
    "ui:capture:nix": "nix-shell -p chromium --run 'node scripts/ui_capture_nix.cjs --urls=http://127.0.0.1:5000 --out=output/playwright'",
    "ui:capture:nix:dev-domain": "nix-shell -p chromium --run 'node scripts/ui_capture_nix.cjs --urls=http://127.0.0.1:5000 --include-dev-domain --out=output/playwright'",
    "ui:capture:nix:prod": "nix-shell -p chromium --run 'node scripts/ui_capture_nix.cjs --urls=http://127.0.0.1:5000 --include-prod --out=output/playwright'",
    "ui:capture:nix:all": "nix-shell -p chromium --run 'node scripts/ui_capture_nix.cjs --urls=http://127.0.0.1:5000 --include-dev-domain --include-prod --out=output/playwright'",
    "flat-files:import": "node scripts/import_massive_flat_files.js",
    "flat-files:backfill:core": "node scripts/backfill_main_targets_flat_files.js",
    "flat-files:progress:core": "node scripts/show_main_targets_flat_file_progress.js",
    "pnl:audit": "node scripts/pnl_integrity_audit.mjs"
  },
  "dependencies": {
    "lightweight-charts": "^5.1.0",
    "mqtt": "^5.15.0",
    "pg": "^8.20.0",
    "playwright": "^1.52.0",
    "protobufjs": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.2",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.5"
  }
}
