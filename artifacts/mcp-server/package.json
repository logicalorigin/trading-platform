{
  "name": "@workspace/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "node ../../scripts/run-validation-command.mjs --label typecheck -- tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test --test-reporter=spec"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "drizzle-orm": "catalog:",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "esbuild": "catalog:",
    "tsx": "catalog:"
  }
}
