#!/bin/bash
set -Eeuo pipefail

umask 077

readonly RUNTIME_DIR=/run/pyrus
readonly LOG_DIR=${RUNTIME_DIR}/logs
readonly PID_DIR=${RUNTIME_DIR}/pids
readonly CPG_HOME=/opt/ibkr/clientportal
readonly CPG_CERT_SHA256=13daf89a0712b962c3ecaa5ede344100aee0d3b5dec5a79abd7602a812eda3be
readonly CPG_SPKI_SHA256='QoH2+wIocE83ZkR4/oyn5ru2JtE+/ZrYS9brNjujldU='
readonly MARKER_FD=${PYRUS_IBKR_CAPSULE_MARKER_FD:-}
declare -a children=()
declare -A child_names=()

if [[ ! "${MARKER_FD}" =~ ^[1-9][0-9]{0,8}$ ]] ||
  [[ ! -e "/proc/self/fd/${MARKER_FD}" ]]; then
  exit 1
fi

mkdir -p \
  "${HOME}" \
  "${XDG_RUNTIME_DIR}" \
  "${RUNTIME_DIR}/chromium" \
  "${LOG_DIR}" \
  "${PID_DIR}"
chmod 0700 "${HOME}" "${XDG_RUNTIME_DIR}"
printf '%s\n' "$$" >"${PID_DIR}/supervisor.pid"

start_service() {
  local name=$1
  shift
  "$@" >>"${LOG_DIR}/${name}.log" 2>&1 &
  local pid=$!
  children+=("${pid}")
  child_names["${pid}"]="${name}"
  printf '%s\n' "${pid}" >"${PID_DIR}/${name}.pid"
}

require_stage() {
  local stage=$1
  shift
  if "$@"; then
    return 0
  fi
  if [[ ! "${stage}" =~ ^[a-z0-9-]{1,32}$ ]]; then
    stage=unknown
  fi
  printf 'PYRUS_IBKR_CAPSULE_STARTUP_FAILURE_V1 stage=%s\n' \
    "${stage}" \
    >&"${MARKER_FD}"
  exit 1
}

cleanup() {
  trap - EXIT INT TERM
  if ((${#children[@]} > 0)); then
    kill -TERM "${children[@]}" 2>/dev/null || true
    for ((attempt = 0; attempt < 5; attempt += 1)); do
      local live=0
      for pid in "${children[@]}"; do
        kill -0 "${pid}" 2>/dev/null && live=1
      done
      ((live == 0)) && break
      sleep 1
    done
    kill -KILL "${children[@]}" 2>/dev/null || true
    wait "${children[@]}" 2>/dev/null || true
  fi
}

stop_cleanly() {
  exit 0
}

wait_for_path() {
  local path=$1
  local attempts=$2
  for ((attempt = 0; attempt < attempts; attempt += 1)); do
    [[ -e "${path}" ]] && return 0
    sleep 1
  done
  return 1
}

wait_for_port() {
  local port=$1
  local attempts=$2
  for ((attempt = 0; attempt < attempts; attempt += 1)); do
    if { exec 3<>"/dev/tcp/127.0.0.1/${port}"; } 2>/dev/null; then
      exec 3>&- 3<&-
      return 0
    fi
    sleep 1
  done
  return 1
}

wait_for_cpg_login() {
  local port=$1
  local attempts=$2
  local status
  for ((attempt = 0; attempt < attempts; attempt += 1)); do
    status=""
    if { exec 3<>"/dev/tcp/127.0.0.1/${port}"; } 2>/dev/null; then
      printf 'GET / HTTP/1.0\r\nHost: localhost\r\nConnection: close\r\n\r\n' >&3
      IFS= read -r -t 2 status <&3 || true
      exec 3>&- 3<&-
      if [[ "${status}" =~ ^HTTP/[0-9.]+[[:space:]]+(200|302|303)[[:space:]] ]]; then
        return 0
      fi
    fi
    sleep 1
  done
  return 1
}

wait_until_healthy() {
  local consecutive=0
  for ((attempt = 0; attempt < 30; attempt += 1)); do
    if /usr/local/bin/pyrus-capsule-health >/dev/null 2>&1; then
      ((consecutive += 1))
      ((consecutive >= 3)) && return 0
    else
      consecutive=0
    fi
    sleep 1
  done
  return 1
}

watchdog() {
  while sleep 10; do
    /usr/local/bin/pyrus-capsule-health >/dev/null 2>&1 || return 1
  done
}

observe_cpg_logins() {
  local line
  local gateway_log=${LOG_DIR}/gw.current.log
  while [[ ! -f "${gateway_log}" ]]; do
    sleep 1
  done
  # ponytail: the pinned CPG has no structured completion callback; replace
  # this fixed marker when IBKR exposes one. Never copy the matched log line.
  while IFS= read -r line; do
    if [[ "${line}" =~ ^[0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3}[[:space:]]+INFO[[:space:]]+[^[:space:]]+[[:space:]]+GatewayHttpProxy[[:space:]]+:[[:space:]]Client[[:space:]]login[[:space:]]succeeds$ ]]; then
      printf 'PYRUS_IBKR_CAPSULE_LOGIN_COMPLETE_V1\n' >&"${MARKER_FD}"
    fi
  done < <(tail -n 0 -F "${gateway_log}")
}

trap cleanup EXIT
trap stop_cleanly INT TERM

# This loopback-only desktop supervisor is the first local-agent slice. A
# later authenticated control tunnel can consume noVNC without publishing it.
start_service xvfb Xvfb :99 -screen 0 1364x768x24 -nolisten tcp -noreset
require_stage xvfb-path wait_for_path /tmp/.X11-unix/X99 20

# No VNC password is stored: the RFB listener is reachable only from loopback
# inside the capsule. noVNC is reachable only through the fixed host-loopback
# Docker relay owned by the session host.
start_service vnc x11vnc \
  -display :99 \
  -rfbport 5900 \
  -listen 127.0.0.1 \
  -forever \
  -shared \
  -nopw
start_service novnc websockify \
  --web=/usr/share/novnc/ \
  0.0.0.0:16080 \
  127.0.0.1:5900

start_service cpg java \
  -server \
  -Dvertx.disableDnsResolver=true \
  -Djava.net.preferIPv4Stack=true \
  -Dvertx.logger-delegate-factory-class-name=io.vertx.core.logging.SLF4JLogDelegateFactory \
  -Dnologback.statusListenerClass=ch.qos.logback.core.status.OnConsoleStatusListener \
  -cp "${CPG_HOME}/root:${CPG_HOME}/dist/ibgroup.web.core.iblink.router.clientportal.gw.jar:${CPG_HOME}/build/lib/runtime/*" \
  ibgroup.web.core.clientportal.gw.GatewayStart \
  --conf ../root/conf.yaml
require_stage cpg-port wait_for_port 5000 60

start_service cpg-relay /usr/local/bin/pyrus-capsule-relay \
  15000 \
  5000 \
  "${CPG_CERT_SHA256}"
require_stage cpg-login wait_for_cpg_login 15000 60

start_service login-observer observe_cpg_logins

start_service chromium chromium \
  --user-data-dir="${RUNTIME_DIR}/chromium" \
  --no-first-run \
  --no-default-browser-check \
  --disable-background-networking \
  --disable-component-update \
  --disable-sync \
  --window-position=0,0 \
  --window-size=1364,768 \
  --ignore-certificate-errors-spki-list="${CPG_SPKI_SHA256}" \
  --app=https://localhost:5000/

require_stage stack-health wait_until_healthy
printf 'PYRUS_IBKR_CAPSULE_READY_V1\n'
start_service watchdog watchdog

# A critical child exit is a capsule failure. Docker's on-failure policy can
# then restart the whole coherent stack instead of leaving a partial session.
failed_pid=0
set +e
wait -n -p failed_pid "${children[@]}"
failed_status=$?
set -e
failed_name=${child_names["${failed_pid}"]:-unknown}
if [[ ! "${failed_name}" =~ ^[a-z0-9-]{1,32}$ ]]; then
  failed_name=unknown
fi
printf 'PYRUS_IBKR_CAPSULE_CHILD_EXIT_V1 name=%s status=%d\n' \
  "${failed_name}" \
  "${failed_status}" \
  >&"${MARKER_FD}"
exit 1
