{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; export PORT=${PORT:-8080} NODE_ENV=development MALLOC_ARENA_MAX=${MALLOC_ARENA_MAX:-2} PYRUS_SIGNAL_MONITOR_BAR_EVALUATION_ENABLED=${PYRUS_SIGNAL_MONITOR_BAR_EVALUATION_ENABLED:-false}; pnpm run build && node ../../scripts/reap-dev-port.mjs && exec node --enable-source-maps ./dist/index.mjs",
    "build": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; node ./build.mjs",
    "start": "unset REPLIT_LD_LIBRARY_PATH LD_LIBRARY_PATH; exec node --enable-source-maps ./dist/index.mjs",
    "typecheck": "node ../../scripts/run-validation-command.mjs --label typecheck -- tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/account-math": "workspace:*",
    "@workspace/api-zod": "workspace:*",
    "@workspace/backtest-core": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/ibkr-contracts": "workspace:*",
    "@workspace/market-calendar": "workspace:*",
    "@workspace/pyrus-signals-core": "workspace:*",
    "cors": "catalog:",
    "drizzle-orm": "catalog:",
    "express": "catalog:",
    "jose": "6.2.3",
    "pino": "catalog:",
    "pino-http": "catalog:",
    "ws": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "esbuild": "catalog:",
    "esbuild-plugin-pino": "catalog:",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
