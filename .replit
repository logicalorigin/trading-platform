modules = ["nodejs-24", "python-3.11", "postgresql-16"]
audio = true

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "artifacts/pyrus: web"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 18747
externalPort = 3000

[userenv]

[userenv.development]
PYRUS_SIGNALS_INCREMENTAL_EVAL = "shadow"
PYRUS_SIGNALS_STORED_BARS_DELTA = "shadow"
PYRUS_SIGNAL_OPTIONS_WIRE_TRAIL_LIVE = "1"

[userenv.shared]
TZ = "America/Denver"

[nix]
channel = "stable-25_05"
