{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build:api-deployment": "pnpm --filter @workspace/api-server run build",
    "build:market-data-worker": "node scripts/run-market-data-worker.mjs build --release -p market-data-worker",
    "build:pyrus-app": "pnpm run audit:guards && pnpm --filter @workspace/pyrus run build && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/ibkr-session-host run build",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "deadcode": "PORT=18747 BASE_PATH=/ knip --include files,dependencies,catalog --no-config-hints",
    "deadcode:prod": "PORT=18747 BASE_PATH=/ knip --production --include files,exports,types,duplicates --no-config-hints --workspace @workspace/pyrus --workspace @workspace/api-server --workspace @workspace/backtest-worker --workspace @workspace/mcp-server --workspace @workspace/api-client-react --workspace @workspace/account-math --workspace @workspace/api-zod --workspace @workspace/api-spec --workspace @workspace/db --workspace @workspace/market-calendar --workspace @workspace/backtest-core --workspace @workspace/pyrus-signals-core --workspace @workspace/ibkr-contracts",
    "diagnose:agent-restarts": "node scripts/diagnose-agent-restarts.mjs",
    "ibkr:capsule:density": "node scripts/ibkr-capsule-density.mjs",
    "ibkr:capsule:release": "node scripts/ibkr-capsule-release.mjs",
    "shot": "node scripts/headless-shot.mjs",
    "audit:api-codegen": "node scripts/check-api-codegen-drift.mjs",
    "audit:branding": "node scripts/check-legacy-branding.mjs",
    "audit:canonical-signal-env": "node scripts/check-canonical-signal-env.mjs",
    "audit:env": "node scripts/check-env-example.mjs",
    "audit:markdown-paths": "node scripts/check-markdown-paths.mjs",
    "audit:publish-context": "node scripts/check-publish-context.mjs",
    "audit:replit-startup": "node scripts/check-replit-startup-guards.mjs",
    "audit:retired-alert-tier": "node scripts/check-retired-alert-tier-references.mjs",
    "audit:session-persistence-security": "node --test scripts/lib/redact-persisted-text.test.mjs && node --test scripts/diagnose-agent-restarts.test.mjs && node --test .agents/skills/session-handoff/scripts/write-session-handoff.test.mjs && node --test scripts/codex-autosave-handoff.test.mjs",
    "audit:guards": "pnpm run audit:publish-context && pnpm run audit:replit-startup && pnpm run audit:env && pnpm run audit:markdown-paths && pnpm run audit:branding && pnpm run audit:canonical-signal-env && pnpm run audit:retired-alert-tier && pnpm run audit:api-codegen && pnpm run audit:session-persistence-security",
    "replit:config:lock": "node scripts/protect-replit-config.mjs lock",
    "replit:config:unlock": "node scripts/protect-replit-config.mjs unlock",
    "replit:config:status": "node scripts/protect-replit-config.mjs status",
    "replit:config:restore": "node scripts/restore-replit-config.mjs",
    "replit:scribe:artifacts": "pnpm --filter @workspace/scripts run replit:scribe:artifacts",
    "db:market-data:audit": "pnpm --filter @workspace/scripts run db:market-data:audit",
    "db:phase0:audit": "pnpm --filter @workspace/scripts run db:phase0:audit",
    "db:snapshot-retention:audit": "pnpm --filter @workspace/scripts run db:snapshot-retention:audit",
    "db:snapshot-retention": "pnpm --filter @workspace/scripts run db:snapshot-retention",
    "fmt:market-data-worker": "node scripts/run-market-data-worker.mjs fmt --check -p market-data-worker",
    "market-data-worker:doctor": "node scripts/run-market-data-worker.mjs run -p market-data-worker -- doctor",
    "market-data-worker:run": "node scripts/run-market-data-worker.mjs run -p market-data-worker -- run",
    "market-data-worker:retention": "node scripts/run-market-data-worker.mjs run -p market-data-worker -- retention",
    "market-data-worker:once": "node scripts/run-market-data-worker.mjs run -p market-data-worker -- once",
    "python-compute:doctor": "node scripts/run-python-compute.mjs doctor",
    "python-compute:benchmark": "node scripts/run-python-compute.mjs benchmark",
    "python-compute:service": "node scripts/run-python-compute.mjs service",
    "python-compute:lint": "node scripts/run-python-compute.mjs lint",
    "python-compute:typecheck": "node scripts/run-python-compute.mjs typecheck",
    "python-compute:test": "node scripts/run-python-compute.mjs test",
    "typecheck:libs": "node scripts/run-validation-command.mjs --label typecheck:libs -- tsc --build",
    "typecheck": "pnpm run audit:publish-context && pnpm run audit:replit-startup && pnpm run typecheck:libs && pnpm -r --workspace-concurrency=1 --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "knip": "^5.88.1",
    "typescript": "~5.9.2"
  }
}
